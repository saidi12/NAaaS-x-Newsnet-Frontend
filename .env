# Relative API base — same build works on localhost, LAN, and via ngrok.
# All requests go through the same origin (nginx proxies /api -> gateway).
REACT_APP_API_URL=/api

# --- Needed when serving the dev server through nginx/ngrok ---
# ngrok sends its own hostname; the CRA dev server rejects unknown hosts without this.
DANGEROUSLY_DISABLE_HOST_CHECK=true
# Make the hot-reload websocket use the page's own (public/https) origin instead of localhost.
WDS_SOCKET_PORT=0
